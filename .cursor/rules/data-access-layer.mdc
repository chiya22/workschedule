## ビジネスルールチェックの分離

複雑な業務ルールは別関数に分離してテストしやすくします。

```ts
// lib/data/reservation-shared.ts

async function checkBusinessRules(
  input: ReservationInput
): Promise<Result<void, string>> {
  const supabase = createClient()

  // 営業時間チェック（DB の stores はない。UI / lib/calendar の定数で扱う）
  // if (isOutsideBusinessHours(...)) { console.warn(...) }

  // 貸し切り時の他予約ブロックチェック（店舗スコープなし・全予約が対象）
  if (input.category === 'private') {
    const { data: conflicts } = await supabase
      .from('reservations')
      .select('id')
      .neq('status', 'cancelled')
      .lt('start_at', input.end_at)
      .gt('end_at', input.start_at)

    if (conflicts && conflicts.length > 0) {
      return {
        success: false,
        error: 'この時間帯は他の予約があるため貸し切りできません',
      }
    }
  }

  // 既存の貸し切り予約と被らないかチェック
  const { data: privateBookings } = await supabase
    .from('reservations')
    .select('id')
    .eq('category', 'private')
    .neq('status', 'cancelled')
    .lt('start_at', input.end_at)
    .gt('end_at', input.start_at)

  if (privateBookings && privateBookings.length > 0) {
    return {
      success: false,
      error: 'この時間帯は貸し切り予約のため受け付けられません',
    }
  }

  return { success: true, data: undefined }
}
```

