## コンポーネント側からの呼び出し

### Server Component（取得）

```tsx
// app/(dashboard)/calendar/page.tsx
import { getReservationsByDateRange } from '@/lib/data/reservations'

export default async function Page() {
  const reservations = await getReservationsByDateRange(...)
  return <CalendarView initialReservations={reservations} />
}
```

### Client Component（更新）

```tsx
'use client'

import { createReservation } from '@/lib/data/reservation-actions'

export function NewReservationModal({ onClose }) {
  async function handleSubmit(data: FormData) {
    const result = await createReservation({ ... })
    if (!result.success) {
      toast.error(result.error)
      return
    }
    onClose()
  }

  return <form action={handleSubmit}>...</form>
}
```

