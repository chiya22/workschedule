## オンボーディングフロー

新規ユーザーがサインアップ後、`/onboarding` で staff レコードを作成します。

### 1人目（オーナー）の判定

```ts
'use server'

export async function completeOnboarding(
  formData: FormData
): Promise<Result<void, string>> {
  const supabase = createClient()
  const { data: { user } } = await supabase.auth.getUser()

  if (!user) {
    return { success: false, error: '認証が必要です' }
  }

  // 既存のスタッフ数をチェック
  const { count } = await supabase
    .from('staff')
    .select('id', { count: 'exact', head: true })

  // 1人目はオーナー、2人目以降は招待コードに従う
  let role: 'owner' | 'manager' | 'staff' = 'owner'

  if (count && count > 0) {
    // 招待コードの検証
    const inviteCode = formData.get('invite_code') as string | null
    if (!inviteCode) {
      return {
        success: false,
        error: '既にスタッフが登録されています。招待コードを入力してください',
      }
    }

    const inviteResult = await consumeInviteCode(inviteCode, user.id)
    if (!inviteResult.success) {
      return inviteResult
    }
    role = inviteResult.data.role
  }

  // staff レコード作成
  const name = formData.get('name') as string
  const { error } = await supabase.from('staff').insert({
    user_id: user.id,
    name,
    role,
  })

  if (error) {
    return { success: false, error: 'スタッフ登録に失敗しました' }
  }

  redirect('/calendar')
}
```

