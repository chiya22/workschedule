## バリデーション

ユーザー入力のバリデーションには **Zod** を使用してください。

```ts
import { z } from 'zod'

export const reservationSchema = z.object({
  customer_name: z.string().min(1, '顧客名を入力してください').max(100),
  party_size: z.number().int().min(1).max(50),
  table_id: z.string().uuid(),
  category: z.enum(['normal', 'course', 'private', 'waitlist', 'vip']),
  start_at: z.string().datetime(),
  end_at: z.string().datetime(),
  notes: z.string().max(500).optional(),
}).refine(
  (data) => new Date(data.end_at) > new Date(data.start_at),
  { message: '終了時刻は開始時刻より後である必要があります', path: ['end_at'] }
)

export type ReservationInput = z.infer<typeof reservationSchema>
```

### Server Action でのバリデーション

```ts
'use server'

export async function createReservation(formData: FormData) {
  const parsed = reservationSchema.safeParse({
    customer_name: formData.get('customer_name'),
    party_size: Number(formData.get('party_size')),
    // ...
  })

  if (!parsed.success) {
    return { error: parsed.error.flatten().fieldErrors }
  }

  // parsed.data を使って処理
}
```

