## 早期リターン

ネストを深くせず、早期リターンで読みやすくしてください。

```ts
// ❌ Bad: ネストが深い
function process(reservation: Reservation | null) {
  if (reservation) {
    if (reservation.status === 'confirmed') {
      if (reservation.party_size > 0) {
        // 処理
      }
    }
  }
}

// ✅ Good: 早期リターン
function process(reservation: Reservation | null) {
  if (!reservation) return
  if (reservation.status !== 'confirmed') return
  if (reservation.party_size <= 0) return

  // 処理
}
```

