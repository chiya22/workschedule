## 命名規則

### ファイル・ディレクトリ

```
コンポーネント       : PascalCase  → ReservationBlock.tsx
hooks               : camelCase    → useReservations.ts
ユーティリティ       : kebab-case   → format-date.ts
型定義              : kebab-case   → reservation-types.ts
ディレクトリ         : kebab-case   → calendar-views/
```

### 識別子

```ts
// 変数・関数: camelCase
const reservationCount = 10
function fetchReservations() {}

// 定数: SCREAMING_SNAKE_CASE
const MAX_PARTY_SIZE = 50
const DEFAULT_RESERVATION_DURATION_MINUTES = 90

// 型・インターフェース: PascalCase
type Reservation = { ... }
interface CalendarProps { ... }

// React コンポーネント: PascalCase
function WeekView() {}

// Boolean: is / has / can / should プレフィックス
const isLoading = true
const hasError = false
const canEdit = true
```

### 関数命名

```ts
// データ取得: fetch / get / load
async function fetchReservations() {}
function getReservationById(id: string) {}

// データ作成・更新: create / update / save
async function createReservation(input: ReservationInput) {}

// 削除: delete / remove
async function deleteReservation(id: string) {}

// 判定: is / has / check
function isOverlapping(a: Reservation, b: Reservation): boolean {}

// 変換: format / parse / convert / to
function formatDateForDisplay(date: Date): string {}
function parseReservationFromForm(formData: FormData): ReservationInput {}
```

