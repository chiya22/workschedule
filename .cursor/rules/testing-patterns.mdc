## コンポーネントテスト

### 基本構造

```tsx
// components/calendar/ReservationBlock.test.tsx
import { describe, it, expect, vi } from 'vitest'
import { render, screen } from '@testing-library/react'
import userEvent from '@testing-library/user-event'
import { ReservationBlock } from './ReservationBlock'

describe('ReservationBlock', () => {
  const mockReservation = {
    id: 'r1',
    customer_name: '田中様',
    party_size: 4,
    category: 'normal' as const,
    start_at: '2026-05-03T18:00:00+09:00',
    end_at: '2026-05-03T19:30:00+09:00',
    table: { name: 'A-2', capacity: 4 },
  }

  it('顧客名と人数を表示する', () => {
    render(<ReservationBlock reservation={mockReservation} onClick={() => {}} />)

    expect(screen.getByText(/田中様/)).toBeInTheDocument()
    expect(screen.getByText(/4名/)).toBeInTheDocument()
  })

  it('テーブル番号を表示する', () => {
    render(<ReservationBlock reservation={mockReservation} onClick={() => {}} />)

    expect(screen.getByText('A-2')).toBeInTheDocument()
  })

  it('クリック時に onClick が呼ばれる', async () => {
    const handleClick = vi.fn()
    render(<ReservationBlock reservation={mockReservation} onClick={handleClick} />)

    await userEvent.click(screen.getByRole('button'))

    expect(handleClick).toHaveBeenCalledWith(mockReservation)
  })

  it('VIP カテゴリの場合、紫の左ボーダーが適用される', () => {
    const vipReservation = { ...mockReservation, category: 'vip' as const }
    const { container } = render(
      <ReservationBlock reservation={vipReservation} onClick={() => {}} />
    )

    const block = container.firstChild as HTMLElement
    expect(block.className).toContain('border-l-reservation-vip')
  })
})
```

### Testing Library のベストプラクティス

ユーザーから見える要素で取得するのが原則です。

```tsx
// ✅ Good: ユーザーが見える要素で取得
screen.getByRole('button', { name: '予約を作成' })
screen.getByLabelText('顧客名')
screen.getByText('田中様')

// ❌ Bad: 実装詳細に依存
screen.getByTestId('submit-button')  // 最終手段としてのみ使用
container.querySelector('.btn-primary')
```

