## 時刻を扱うテスト

```ts
import { describe, it, expect, vi, beforeEach, afterEach } from 'vitest'

describe('現在時刻に依存する処理', () => {
  beforeEach(() => {
    vi.useFakeTimers()
    vi.setSystemTime(new Date('2026-05-03T15:30:00+09:00'))
  })

  afterEach(() => {
    vi.useRealTimers()
  })

  it('現在時刻が15:30の場合、現在時刻ラインが正しい位置に表示される', () => {
    const position = calculateNowLinePosition()
    // 11:00 開始から 4.5 時間 × 60px = 270px
    expect(position).toBe(270)
  })
})
```

