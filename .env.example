# このファイルをコピーして .env.local を作成し、値を埋めてください。
# Supabase: Project Settings > API

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# サーバー専用（スタッフアカウントの作成・削除・ログイン識別子変更などに必要。クライアントへ出さない）
SUPABASE_SERVICE_ROLE_KEY=

# オーナー向け予約通知メール（Resend: https://resend.com）。未設定なら送信しません。
RESEND_API_KEY=
# Resend で検証済みドメインの From（例: Reservations <booking@yourdomain.com>）
RESERVATION_NOTIFY_FROM=
